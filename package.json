{
  "name": "davicafu-tailwind-d3-animated",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./dist/styles.css --minify",
    "dev:css": "tailwindcss -c tailwind.config.js -i ./src/input.css -o ./dist/styles.css --watch",
    "lint": "eslint \"**/*.js\" --ignore-pattern node_modules --ignore-pattern dist",
    "format": "prettier --write \"**/*.{html,css,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "@sparticuz/chromium": "^138.0.2",
    "eslint": "^9.36.0",
    "eslint-plugin-html": "^8.1.3",
    "puppeteer-core": "^24.19.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17"
  }
}
